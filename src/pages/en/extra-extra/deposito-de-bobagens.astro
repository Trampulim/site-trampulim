---
import Layout from '../../../layouts/Layout.astro';

const channelUrl = 'https://www.youtube.com/GrupoTrampulim';

const videos = [
  'SjYSDXdwT9E', '2trSyyfmiLI', 'dqCLR5qAS4Q', 'FlBrG1S-_mk', '9gN1CNyqsL4',
  'kODAsQxNN9A', 'Lvj2LdzOxU0', 'CF71dI6FAzo', 'DA9MLx4g3yg', 'LDe_OS4xMt4',
  '5UHzsmfvU8I', 'NRunuc0KK94', 'SCs2xWXeN-c', 'faOecG0jEZg', 'ithl6hijbnc',
  '6hg2NRf1KBE', 'RiRcdn8-ROY', '9CfoRxX28w0', 'HCO4qu05He4', 'kK2PaSy3hR4',
];
---

<Layout title="Oddities Cabinet" description="Videos from Grupo Trampulim's YouTube channel — shows, behind the scenes and audiovisual productions." lang="en">
  <section class="container-site py-16">
    <p class="eyebrow mb-2">Extra, Extra</p>
    <h1 class="text-4xl md:text-5xl font-display font-bold mb-4">Oddities Cabinet</h1>
    <p class="text-trampulim-text/60 max-w-xl mb-12 leading-relaxed">
      Shows, behind the scenes, experiments and all kinds of nonsense. A selection of videos from our YouTube channel.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {videos.map((id) => (
        <button
          type="button"
          class="yt-facade group relative aspect-video w-full overflow-hidden shadow-sm bg-trampulim-dark cursor-pointer"
          data-videoid={id}
          aria-label="Play video"
        >
          <img
            src={`https://i.ytimg.com/vi/${id}/hqdefault.jpg`}
            alt=""
            class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity"
            loading="lazy"
          />
          <span class="absolute inset-0 flex items-center justify-center">
            <span class="w-14 h-14 rounded-full bg-trampulim-red flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
              <svg class="w-6 h-6 text-white ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </span>
          </span>
        </button>
      ))}
    </div>

    <div class="text-center mt-12">
      <a href={channelUrl} target="_blank" rel="noopener noreferrer" class="btn-secondary">
        See all on YouTube
      </a>
    </div>
  </section>
</Layout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.yt-facade').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.videoid;
      if (!id) return;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1`;
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.className = 'w-full h-full absolute inset-0';
      btn.innerHTML = '';
      btn.appendChild(iframe);
    });
  });
</script>
