---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Contact"
  description="Get in touch with Grupo Trampulim — shows, workshops, corporate events and more."
  lang="en"
>
  <section class="container-site py-16 max-w-4xl">
    <p class="text-trampulim-red uppercase tracking-widest text-xs font-semibold mb-2">Contact</p>
    <h1 class="section-title">Get in touch</h1>
    <p class="text-gray-500 max-w-xl mb-12">
      Want to book a show, a workshop or a corporate project? Have a question or proposal?
      Choose your preferred channel.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <div>
        <h2 class="text-xl font-display mb-6">Send a message</h2>
        <form name="contato-en" method="POST" action="/en/contato?enviado=true" class="space-y-4">
          <div>
            <label for="nome" class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
            <input type="text" id="nome" name="nome" required class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-trampulim-red/30 focus:border-trampulim-red transition" placeholder="Your full name" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1">E-mail *</label>
            <input type="email" id="email" name="email" required class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-trampulim-red/30 focus:border-trampulim-red transition" placeholder="your@email.com" />
          </div>
          <div>
            <label for="mensagem" class="block text-sm font-medium text-gray-700 mb-1">Message *</label>
            <textarea id="mensagem" name="mensagem" required rows="5" class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-trampulim-red/30 focus:border-trampulim-red transition resize-none" placeholder="Tell us about your project or question..."></textarea>
          </div>
          <button type="submit" class="btn-primary w-full text-center">Send message</button>
        </form>
      </div>

      <div class="space-y-8">
        <div>
          <h2 class="text-xl font-display mb-4">Direct contact</h2>
          <div class="space-y-4">
            <a href={`https://wa.me/5531986891687?text=${encodeURIComponent('Hello! I visited the Grupo Trampulim website and would like more information.')}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 bg-[#25D366] text-white rounded-xl px-5 py-4 font-semibold hover:opacity-90 transition-opacity">
              <svg class="w-6 h-6 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp — +55 (31) 98689-1687
            </a>
            <a href="mailto:contato@trampulim.com.br" class="flex items-center gap-3 bg-white border border-gray-200 rounded-xl px-5 py-4 text-gray-700 font-medium hover:border-trampulim-red transition-colors">
              <svg class="w-5 h-5 shrink-0 text-trampulim-red" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              contato@trampulim.com.br
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
