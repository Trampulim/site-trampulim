---

<Layout title="Shows" description="Grupo Trampulim's productions — clown, theatre and performance for all audiences." lang="en">
  <section class="container-site py-16">
    <p class="eyebrow mb-2">Repertoire</p>
    <h1 class="text-4xl md:text-5xl font-display font-bold mb-4">Shows</h1>
    <p class="text-trampulim-text/60 max-w-xl mb-16 leading-relaxed">
      With noses and big shoes packed, Grupo Trampulim has created a magical array of shows over the last 30 years.
    </p>

    <div class="space-y-24">
      {shows.map((e, i) => (
        <article id={e.id} class="scroll-mt-20">
          <h2 class="text-2xl md:text-3xl font-display font-bold mb-6">{e.titulo}</h2>
          <div class={`grid grid-cols-1 md:grid-cols-2 gap-6 mb-6 ${i % 2 === 0 ? '' : 'md:[direction:rtl]'}`}>
            <div class="aspect-video overflow-hidden shadow-lg md:[direction:ltr]">
              <iframe src={`https://www.youtube.com/embed/${e.videoId}`} title={`${e.titulo} — Grupo Trampulim`} allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen class="w-full h-full" loading="lazy"></iframe>
            </div>
            <div class="md:[direction:ltr]">
              <Carrossel id={e.id} fotos={e.fotos} />
            </div>
          </div>
          <p class="text-trampulim-text/70 leading-relaxed max-w-2xl">{e.sinopse}</p>
          {fichas[e.id] && (
            <details class="group mt-5 max-w-2xl border border-gray-200 rounded-xl overflow-hidden">
              <summary class="cursor-pointer list-none px-5 py-3 flex items-center justify-between font-semibold text-sm text-trampulim-dark hover:bg-gray-50 transition-colors">
                <span>Technical sheet</span>
                <span class="text-trampulim-red transition-transform group-open:rotate-45 text-lg leading-none">+</span>
              </summary>
              <dl class="px-5 pb-5 pt-1 grid grid-cols-1 sm:grid-cols-[auto_1fr] gap-x-4 gap-y-2 text-sm">
                {fichas[e.id].map((f) => (
                  <>
                    <dt class="font-semibold text-gray-500">{f.rotulo}</dt>
                    <dd class="text-trampulim-text/80">{f.valor}</dd>
                  </>
                ))}
              </dl>
            </details>
          )}
          <a href={`https://wa.me/5531986891687?text=${encodeURIComponent(`Hello! I am interested in the show "${e.titulo}". I would love more information.`)}`} target="_blank" rel="noopener noreferrer" class="inline-block mt-5 text-sm font-semibold text-trampulim-red hover:underline">
            Request information →
          </a>
          {i < shows.length - 1 && <hr class="mt-16 border-gray-100" />}
        </article>
      ))}
    </div>
  </section>
</Layout>
