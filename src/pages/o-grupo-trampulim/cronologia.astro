<Layout
  title="Cronologia de Montagens"
  description="Linha do tempo das produções e marcos do Grupo Trampulim desde 1994."
>
  <section class="container-site py-16 max-w-3xl">
    <p class="text-trampulim-red uppercase tracking-widest text-xs font-semibold mb-2">Grupo Trampulim</p>
    <h1 class="section-title">Cronologia de Montagens</h1>
    <p class="text-gray-500 mb-10">Trinta anos de criação, pesquisa e palco.</p>

    <ol class="relative border-l border-gray-200 space-y-10">
      {montagens.map((m) => (
        <li class="ml-6">
          <span class="absolute -left-3 flex items-center justify-center w-6 h-6 bg-trampulim-dark rounded-full ring-4 ring-trampulim-light">
            <span class="w-2 h-2 bg-trampulim-yellow rounded-full"></span>
          </span>
          <time class="text-xs font-bold text-trampulim-red uppercase tracking-wider">{m.ano}</time>
          <h3 class="font-semibold text-trampulim-dark mt-0.5 text-lg">{m.titulo}</h3>
          <dl class="mt-2 space-y-1 text-sm text-gray-500">
            <div class="flex gap-2">
              <dt class="font-medium text-gray-700 shrink-0">Concepção:</dt>
              <dd>{m.concepção}</dd>
            </div>
            <div class="flex gap-2">
              <dt class="font-medium text-gray-700 shrink-0">Direção:</dt>
              <dd>{m.direção}</dd>
            </div>
            <div class="flex gap-2">
              <dt class="font-medium text-gray-700 shrink-0">Elenco:</dt>
              <dd>{m.elenco}</dd>
            </div>
          </dl>
        </li>
      ))}
    </ol>
  </section>
</Layout>
