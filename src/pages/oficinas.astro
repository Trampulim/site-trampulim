---
import Layout from '../layouts/Layout.astro';

const oficinas = [
  {
    titulo: 'O Jogo do Palhaço – Estado',
    tipo: 'Iniciação',
    descricao: 'Uma iniciação ao palhaço que desconstrói preconceitos e equipa artistas com ferramentas fundamentais para o trabalho cênico. O estado do palhaço requer uma lógica específica — e esta oficina ensina essa linguagem por meio de jogos cênicos, práticas, treinamentos, pesquisas e reflexões.',
    publicoAlvo: 'Atores, performers, estudantes de artes cênicas e circenses com qualquer nível de experiência.',
  },
  {
    titulo: 'Invenção da Invasão',
    tipo: 'Intervenção de rua',
    descricao: 'Oficina com capacidade para até 30 artistas. Os participantes recebem ferramentas práticas para criar intervenções de rua improvisadas em espaços do cotidiano. Aborda a relação com o espaço público, o transeúnte como cúmplice involuntário e a arte da presença no inesperado.',
    publicoAlvo: 'Artistas de circo, rua e teatro com interesse em intervenção urbana.',
  },
  {
    titulo: 'Oficina Trampulimpro',
    tipo: 'Improvisação teatral',
    descricao: 'A combinação entre o palhaço e a improvisação teatral como prática de expansão da presença cênica. A oficina enfatiza exercícios físicos, espontaneidade e expressão cômica, explorando o que acontece quando o inesperado vira oportunidade de criação.',
    publicoAlvo: 'Profissionais das artes cênicas, estudantes de teatro e artistas de circo.',
  },
];
---

<Layout
  title="Oficinas"
  description="Oficinas de palhaço, improvisação e intervenção de rua do Grupo Trampulim para artistas e estudantes das artes cênicas."
>
  <section class="container-site py-16">
    <p class="text-trampulim-red uppercase tracking-widest text-xs font-semibold mb-2">Formação</p>
    <h1 class="section-title">Oficinas</h1>
    <p class="text-gray-500 max-w-xl mb-12">
      Ser palhaço é um estado que requer uma lógica específica. As oficinas do Grupo Trampulim ensinam
      essa linguagem por meio de jogos cênicos, oferecendo ferramentas para projetos artísticos ou
      desenvolvimento pessoal.
    </p>

    <div class="space-y-8">
      {oficinas.map((o) => (
        <article class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm">
          <p class="text-trampulim-red text-xs font-semibold uppercase tracking-widest mb-1">{o.tipo}</p>
          <h2 class="text-2xl font-display mb-3">{o.titulo}</h2>
          <p class="text-gray-600 leading-relaxed mb-4">{o.descricao}</p>
          <p class="text-sm text-gray-400">
            <span class="font-semibold text-gray-600">Público-alvo:</span> {o.publicoAlvo}
          </p>
        </article>
      ))}
    </div>

    <div class="mt-12 text-center">
      <p class="text-gray-500 mb-6">Interessado em receber uma oficina do Grupo Trampulim?</p>
      <a
        href={`https://wa.me/5531986891687?text=${encodeURIComponent('Olá! Tenho interesse em receber uma oficina do Grupo Trampulim. Gostaria de mais informações.')}`}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
      >
        Falar pelo WhatsApp
      </a>
    </div>
  </section>
</Layout>
