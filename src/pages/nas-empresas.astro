const numeros = [
  { valor: '243+', label: 'eventos corporativos realizados' },
  { valor: '247+', label: 'apresentações do Pratubatê' },
  { valor: '30+', label: 'anos de experiência' },
  { valor: '650+', label: 'tambores prontos para a sua equipe' },
