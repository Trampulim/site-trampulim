  { src: '/galeria/pcorp-g2.jpg', credito: 'João Bosco' },
  { src: '/galeria/pcorp-g3.jpg', credito: 'Divulgação' },
  { src: '/galeria/pcorp-g4.jpg', credito: 'Jackson Romanelli' },
  { src: '/galeria/pcorp-g5.jpg', credito: 'Jackson Romanelli' },
  { src: '/galeria/pcorp-g6.jpg', credito: 'Cecília / Rede Cidadã' },
  { src: '/galeria/pcorp-g7.jpg', credito: 'Polyane Santos' },
  { src: '/galeria/pcorp-g8.jpg', credito: 'Divulgação' },
  { src: '/galeria/pcorp-g9.jpg', credito: 'Divulgação' },
  { src: '/galeria/pcorp-g10.jpg', credito: 'Divulgação' },
  { src: '/galeria/pcorp-g11.jpg', credito: 'Divulgação' },
