---

<Layout
  title="Espetáculos"
  description="As produções teatrais do Grupo Trampulim — palhaçaria, teatro e performance para todos os públicos."
>
  <section class="container-site py-16">
    <p class="eyebrow mb-2">Repertório</p>
    <h1 class="text-4xl md:text-5xl font-display font-bold mb-4">Espetáculos</h1>
    <p class="text-trampulim-text/60 max-w-xl mb-16 leading-relaxed">
      Com nariz e sapato na bagagem, o Grupo Trampulim criou, nos últimos 30 anos, uma porção mágica de espetáculos.
    </p>

    <div class="space-y-24">
      {espetaculos.map((e, i) => (
        <article id={e.id} class="scroll-mt-20">
          <h2 class="text-2xl md:text-3xl font-display font-bold mb-6">{e.titulo}</h2>

          <!-- Vídeo + Carrossel lado a lado no desktop -->
          <div class={`grid grid-cols-1 md:grid-cols-2 gap-6 mb-6 ${i % 2 === 0 ? '' : 'md:[direction:rtl]'}`}>

            <!-- Vídeo release -->
            <div class="aspect-video overflow-hidden shadow-lg md:[direction:ltr]">
              <iframe
                src={`https://www.youtube.com/embed/${e.videoId}`}
                title={`${e.titulo} — Grupo Trampulim`}
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                class="w-full h-full"
                loading="lazy"
              ></iframe>
            </div>

            <!-- Carrossel de fotos -->
            <div class="md:[direction:ltr]">
              <Carrossel id={e.id} fotos={e.fotos} />
            </div>
          </div>

          <!-- Sinopse -->
          <p class="text-trampulim-text/70 leading-relaxed max-w-2xl">{e.sinopse}</p>

          <!-- Ficha técnica expansível -->
          {fichas[e.id] && (
            <details class="group mt-5 max-w-2xl border border-gray-200 rounded-xl overflow-hidden">
              <summary class="cursor-pointer list-none px-5 py-3 flex items-center justify-between font-semibold text-sm text-trampulim-dark hover:bg-gray-50 transition-colors">
                <span>Saiba mais — Ficha técnica</span>
                <span class="text-trampulim-red transition-transform group-open:rotate-45 text-lg leading-none">+</span>
              </summary>
              <dl class="px-5 pb-5 pt-1 grid grid-cols-1 sm:grid-cols-[auto_1fr] gap-x-4 gap-y-2 text-sm">
                {fichas[e.id].map((f) => (
                  <>
                    <dt class="font-semibold text-gray-500">{f.rotulo}</dt>
                    <dd class="text-trampulim-text/80">{f.valor}</dd>
                  </>
                ))}
              </dl>
            </details>
          )}

          <!-- CTA WhatsApp -->
          <a
            href={`https://wa.me/5531986891687?text=${encodeURIComponent(`Olá! Tenho interesse no espetáculo "${e.titulo}". Gostaria de mais informações.`)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block mt-5 text-sm font-semibold text-trampulim-red hover:underline"
          >
            Solicitar informações →
          </a>

          {i < espetaculos.length - 1 && (
            <hr class="mt-16 border-gray-100" />
          )}
        </article>
      ))}
    </div>
  </section>
</Layout>
