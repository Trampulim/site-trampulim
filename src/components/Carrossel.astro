---
interface Foto {
  src: string;
  credito: string;
}

interface Props {
  id: string;
  fotos: Foto[];
}

const { id, fotos } = Astro.props;
---

<div class="relative w-full" id={`carrossel-${id}`}>
  <!-- Track de fotos -->
  <div class="overflow-hidden">
    <div
      class="flex transition-transform duration-500 ease-in-out"
      style="width: 100%"
      data-track
    >
      {fotos.map((foto, i) => (
        <div class="relative w-full flex-shrink-0 aspect-[4/3] bg-trampulim-dark flex items-center justify-center">
          <img
            src={foto.src}
            alt=""
            loading="lazy"
            class="w-full h-full object-contain"
          />
          <span class="absolute bottom-2 right-3 text-white/70 text-[10px] bg-black/40 backdrop-blur-sm px-2 py-0.5 rounded-full">
            © {foto.credito}
          </span>
        </div>
      ))}
    </div>
  </div>

  <!-- Botões de navegação -->
  {fotos.length > 1 && (
    <>
      <button
        class="absolute left-2 top-1/2 -translate-y-1/2 bg-black/50 hover:bg-black/70 text-white rounded-full w-9 h-9 flex items-center justify-center transition-colors z-10"
        data-prev
        aria-label="Foto anterior"
      >
        ‹
      </button>
      <button
        class="absolute right-2 top-1/2 -translate-y-1/2 bg-black/50 hover:bg-black/70 text-white rounded-full w-9 h-9 flex items-center justify-center transition-colors z-10"
        data-next
        aria-label="Próxima foto"
      >
        ›
      </button>

      <!-- Indicadores -->
      <div class="flex justify-center gap-1.5 mt-3">
        {fotos.map((_, i) => (
          <button
            class="w-2 h-2 rounded-full bg-gray-300 hover:bg-trampulim-red transition-colors"
            data-dot={i}
            aria-label={`Ir para foto ${i + 1}`}
          ></button>
        ))}
      </div>
    </>
  )}
</div>

<script define:vars={{ id, total: fotos.length }}>
  (function () {
    const container = document.getElementById(`carrossel-${id}`);
    if (!container) return;

    const track = container.querySelector('[data-track]');
    const dots = container.querySelectorAll('[data-dot]');
    const prev = container.querySelector('[data-prev]');
    const next = container.querySelector('[data-next]');

    let current = 0;

    function go(index) {
      current = (index + total) % total;
      track.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => {
        d.classList.toggle('bg-trampulim-red', i === current);
        d.classList.toggle('bg-gray-300', i !== current);
      });
    }

    go(0);

    if (prev) prev.addEventListener('click', () => go(current - 1));
    if (next) next.addEventListener('click', () => go(current + 1));
    dots.forEach((d, i) => d.addEventListener('click', () => go(i)));
  })();
</script>
