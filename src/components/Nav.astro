---
import { nav, getAlternateUrl, type Lang } from '../i18n/index';

interface Props {
  lang?: Lang;
  currentPath?: string;
}

const { lang = 'pt', currentPath = '/' } = Astro.props;
const t = nav[lang];
const prefix = lang === 'pt' ? '' : `/${lang}`;

const navItems = [
  {
    label: t.grupo,
    href: `${prefix}/o-grupo-trampulim/historico`,
    children: [
      { label: t.historico, href: `${prefix}/o-grupo-trampulim/historico` },
      { label: t.ficha, href: `${prefix}/o-grupo-trampulim/ficha-tecnica` },
      { label: t.premios, href: `${prefix}/o-grupo-trampulim/premios` },
      { label: t.cronologia, href: `${prefix}/o-grupo-trampulim/cronologia` },
    ],
  },
  {
    label: t.repertorio,
    href: `${prefix}/repertorio/espetaculos`,
    children: [
      { label: t.espetaculos, href: `${prefix}/repertorio/espetaculos` },
      { label: t.intervencoes, href: `${prefix}/repertorio/intervencoes-e-numeros` },
    ],
  },
  { label: t.empresas, href: `${prefix}/nas-empresas` },
  { label: t.oficinas, href: `${prefix}/oficinas` },
  { label: t.deposito, href: `${prefix}/extra-extra/deposito-de-bobagens` },
  { label: t.contato, href: `${prefix}/contato` },
];

const langs: { code: Lang; label: string }[] = [
  { code: 'pt', label: 'PT' },
  { code: 'es', label: 'ES' },
  { code: 'en', label: 'EN' },
];
---

<header class="bg-white text-trampulim-dark sticky top-0 z-40 shadow-sm border-b border-gray-100">
  <div class="container-site flex items-center justify-between py-3">

    <a href="/" aria-label="Grupo Trampulim — início">
      <img src="/marca-trampulim-grande.png" alt="Grupo Trampulim" class="h-10 w-auto" />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-6 text-sm font-medium">
      {navItems.map((item) => (
        <div class="relative group">
          <a href={item.href} class="hover:text-trampulim-red transition-colors py-2 inline-block">
            {item.label}
          </a>
          {item.children && (
            <ul class="absolute left-0 top-full bg-white border border-gray-100 rounded-md py-2 min-w-[200px] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 shadow-lg">
              {item.children.map((child) => (
                <li>
                  <a href={child.href} class="block px-4 py-2 hover:bg-gray-50 hover:text-trampulim-red transition-colors text-gray-700">
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </div>
      ))}
    </nav>

    <!-- Language switcher (desktop) -->
    <div class="hidden md:flex items-center gap-1 text-xs font-semibold mr-2">
      {langs.map((l, i) => (
        <>
          {i > 0 && <span class="text-gray-300">·</span>}
          <a
            href={getAlternateUrl(currentPath, l.code)}
            class={`px-1 py-0.5 transition-colors ${lang === l.code ? 'text-trampulim-red' : 'text-gray-400 hover:text-trampulim-dark'}`}
            aria-current={lang === l.code ? 'true' : undefined}
          >{l.label}</a>
        </>
      ))}
    </div>

    <!-- Social icons (desktop) -->
    <div class="hidden md:flex items-center gap-3 text-gray-500">
      <a href="https://www.instagram.com/trampulim" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="hover:text-trampulim-red transition-colors">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
      </a>
      <a href="https://www.facebook.com/GrupoTrampulim" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="hover:text-trampulim-red transition-colors">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </a>
      <a href="https://www.youtube.com/GrupoTrampulim" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="hover:text-trampulim-red transition-colors">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>
      </a>
      <a href="https://www.linkedin.com/company/grupo-trampulim/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="hover:text-trampulim-red transition-colors">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
    </div>

    <!-- Mobile burger -->
    <button id="menu-toggle" class="md:hidden p-2" aria-label="Abrir menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100">
    <nav class="container-site py-4 flex flex-col gap-1 text-sm">
      {navItems.map((item) => (
        <>
          <a href={item.href} class="py-2 font-semibold hover:text-trampulim-red transition-colors text-trampulim-dark">
            {item.label}
          </a>
          {item.children && item.children.map((child) => (
            <a href={child.href} class="py-1 pl-4 text-gray-500 hover:text-trampulim-red transition-colors">
              {child.label}
            </a>
          ))}
        </>
      ))}
      <!-- Language switcher (mobile) -->
      <div class="flex gap-2 text-xs font-semibold mt-2 mb-2">
        {langs.map((l, i) => (
          <>
            {i > 0 && <span class="text-gray-300">·</span>}
            <a
              href={getAlternateUrl(currentPath, l.code)}
              class={`px-1 py-0.5 ${lang === l.code ? 'text-trampulim-red' : 'text-gray-400'}`}
            >{l.label}</a>
          </>
        ))}
      </div>

      <div class="flex gap-4 mt-4 pt-4 border-t border-gray-100">
        <a href="https://www.instagram.com/trampulim" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="hover:text-trampulim-red transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
        <a href="https://www.facebook.com/GrupoTrampulim" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="hover:text-trampulim-red transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="https://www.youtube.com/GrupoTrampulim" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="hover:text-trampulim-red transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>
        </a>
        <a href="https://www.linkedin.com/company/grupo-trampulim/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="hover:text-trampulim-red transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  document.getElementById('menu-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
