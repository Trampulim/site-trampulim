<footer class="bg-trampulim-dark text-white mt-16">
  <div class="container-site py-10 grid grid-cols-1 md:grid-cols-3 gap-8">

    <!-- Col 1: Identidade -->
    <div>
      <h3 class="font-display text-xl mb-3">Grupo Trampulim</h3>
      <p class="text-white/60 text-sm leading-relaxed">
        Circo, teatro e palhaçaria desde 1994.<br />
        Belo Horizonte – MG, Brasil.
      </p>
      <p class="text-white/60 text-sm mt-3">
        <a href="mailto:contato@trampulim.com.br" class="hover:text-trampulim-yellow transition-colors">
          contato@trampulim.com.br
        </a>
      </p>
    </div>

    <!-- Col 2: Links rápidos -->
    <div>
      <h4 class="font-semibold mb-3 text-sm uppercase tracking-wider text-white/50">Navegação</h4>
      <ul class="space-y-2 text-sm text-white/70">
        <li><a href="/o-grupo-trampulim/historico" class="hover:text-trampulim-yellow transition-colors">Histórico</a></li>
        <li><a href="/repertorio/espetaculos" class="hover:text-trampulim-yellow transition-colors">Espetáculos</a></li>
